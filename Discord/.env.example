# ─────────────────────────────────────────────
# Discord Bot
# ─────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
GUILD_ID=your_server_id_here

# ─────────────────────────────────────────────
# Role & Verification
# ─────────────────────────────────────────────
VERIFIED_ROLE_ID=0          # Role ID required to claim (0 = disabled)
VERIFY_CHANNEL_ID=0         # Channel to point unverified users to

# ─────────────────────────────────────────────
# Public Catalog Channels
# ─────────────────────────────────────────────
CATALOG_SFW_CHANNEL_ID=0
CATALOG_NSFW_CHANNEL_ID=0

# ─────────────────────────────────────────────
# Staff-Only Claims Archive Channels
# ─────────────────────────────────────────────
CLAIMS_SFW_CHANNEL_ID=0
CLAIMS_NSFW_CHANNEL_ID=0

# ─────────────────────────────────────────────
# Private Upload Storage Threads
# ─────────────────────────────────────────────
UPLOAD_THREAD_RAW_SFW=0
UPLOAD_THREAD_WM_SFW=0
UPLOAD_THREAD_RAW_NSFW=0
UPLOAD_THREAD_WM_NSFW=0

# ─────────────────────────────────────────────
# Watcher (file upload watcher)
# ─────────────────────────────────────────────
WATCHER_PARENT_DIR=F:\YourShowFolder
WM_TEMPLATE_SFW=F:\YourShowFolder\templates\sfw.png
WM_TEMPLATE_NSFW=F:\YourShowFolder\templates\nsfw.png
WATCHER_AUTO_PUBLISH=0      # 1 = auto-post to catalog on upload, 0 = manual

# ─────────────────────────────────────────────
# Bin Show (Whatnot screen watcher)
# ─────────────────────────────────────────────
CLAIM_BOT_COMMANDS_CHANNEL_ID=0  # Channel where host types bin numbers during live show

# ─────────────────────────────────────────────
# Trade System
# ─────────────────────────────────────────────
TRADE_CATEGORY_ID=0            # Discord category where private trade channels are created
TRADE_ANNOUNCE_CHANNEL_ID=0    # Public channel where new listings are announced (0 = disabled)
